{
  "name": "kursim",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "dev:full": "bash scripts/dev-full.sh",
    "build": "prisma generate && next build",
    "start": "next start",
    "test": "vitest run",
    "worker": "node --env-file=.env --import tsx src/worker/course-media-worker.ts",
    "db:migrate": "prisma migrate deploy",
    "db:seed": "tsx prisma/seed.ts",
    "users": "ADMIN_DATABASE_URL=\"${ADMIN_DATABASE_URL:-postgresql://postgres:postgres@localhost:15432/kursim}\" tsx scripts/list-users.ts",
    "postinstall": "prisma generate"
  },
  "dependencies": {
    "@node-rs/argon2": "^2",
    "@prisma/client": "^6",
    "bullmq": "^5.79.3",
    "cloudinary": "^2",
    "ffmpeg-static": "^5.3.0",
    "ioredis": "^5",
    "jose": "^5",
    "next": "^15",
    "react": "^19",
    "react-dom": "^19",
    "zod": "^3"
  },
  "devDependencies": {
    "@types/node": "^22",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "autoprefixer": "^10",
    "ioredis-mock": "^8",
    "postcss": "^8",
    "prisma": "^6",
    "tailwindcss": "^3.4",
    "tsx": "^4",
    "typescript": "^5",
    "vitest": "^2"
  }
}
