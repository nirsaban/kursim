generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum TenantStatus {
  ACTIVE
  SUSPENDED
}

enum UserRole {
  SUPER_ADMIN
  OWNER
  INSTRUCTOR
  STUDENT
}

enum UserStatus {
  ACTIVE
  SUSPENDED
}

enum EvictionPolicy {
  BLOCK
  EVICT_OLDEST
}

enum CourseStatus {
  DRAFT
  PUBLISHED
}

enum AttachmentKind {
  DOC
  IMAGE
  OTHER
}

model Tenant {
  id              String        @id @default(uuid()) @db.Uuid
  slug            String        @unique
  name            String
  status          TenantStatus  @default(ACTIVE)
  sessionLimit    Int           @default(3)
  evictionPolicy  EvictionPolicy @default(BLOCK)
  /// Owner-customizable student-home content (validated by homepageSchema).
  homepage        Json?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  users           User[]
  courses         Course[]
  invites         Invite[]
  modules         Module[]
  lessons         Lesson[]
  attachments     Attachment[]
  enrollments     Enrollment[]
  progress        Progress[]
  reviews         CourseReview[]
  affiliateLinks  AffiliateLink[]
  courseMedia     CourseMedia[]
  learningActivity LearningActivity[]
}

model User {
  id                  String      @id @default(uuid()) @db.Uuid
  tenantId            String?     @db.Uuid
  email               String
  passwordHash        String
  role                UserRole
  status              UserStatus  @default(ACTIVE)
  mustChangePassword  Boolean     @default(false)
  lastLoginAt         DateTime?
  createdAt           DateTime    @default(now())
  updatedAt           DateTime    @updatedAt

  tenant              Tenant?     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  enrollments         Enrollment[]
  progress            Progress[]
  reviews             CourseReview[]
  affiliateLinks      AffiliateLink[]
  learningActivity    LearningActivity[]

  @@unique([tenantId, email])
}

model Invite {
  id        String      @id @default(uuid()) @db.Uuid
  tenantId  String      @db.Uuid
  tokenHash String      @unique
  email     String?
  role      UserRole    @default(STUDENT)
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime    @default(now())

  tenant    Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
}

model Course {
  id               String        @id @default(uuid()) @db.Uuid
  tenantId         String        @db.Uuid
  title            String
  description      String?       @db.Text
  coverPublicId    String?
  status           CourseStatus  @default(DRAFT)
  marketing        Json?
  landingPublished Boolean       @default(false)
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  tenant          Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  modules         Module[]
  enrollments     Enrollment[]
  reviews         CourseReview[]
  affiliateLinks  AffiliateLink[]
  media           CourseMedia?
}

/// AI-generated marketing media for a course landing page: a Veo video rendered
/// as a 240-frame scroll-scrubbed hero sequence, plus Imagen stills. Public
/// (landing pages are public); the "media is never public" rule still governs lessons.
model CourseMedia {
  id            String   @id @default(uuid()) @db.Uuid
  tenantId      String   @db.Uuid
  courseId      String   @unique @db.Uuid
  /// idle | generating | ready | failed
  status        String   @default("idle")
  /// Cloudinary base URL; individual frames appended as /frame_0001.jpg … frame_0240.jpg
  framesBaseUrl String?
  frameCount    Int      @default(240)
  posterUrl     String?
  videoUrl      String?
  /// [{ role, url, aspectRatio }]
  stills        Json?
  /// The full Gemini prompt-writer output, kept for re-runs and debugging.
  promptJson    Json?
  error         String?  @db.Text
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  course Course @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@index([tenantId])
}

model CourseReview {
  id        String   @id @default(uuid()) @db.Uuid
  tenantId  String   @db.Uuid
  courseId  String   @db.Uuid
  studentId String   @db.Uuid
  name        String   @default("")
  rating      Int
  text        String   @db.Text
  /** Private feedback for the owner — never shown on the landing page. */
  privateNote String   @default("") @db.Text
  approved    Boolean  @default(false)
  createdAt   DateTime @default(now())

  tenant  Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  course  Course @relation(fields: [courseId], references: [id], onDelete: Cascade)
  student User   @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([courseId, studentId])
}

model AffiliateLink {
  id        String   @id @default(uuid()) @db.Uuid
  tenantId  String   @db.Uuid
  courseId  String   @db.Uuid
  studentId String   @db.Uuid
  /** Short public share code carried as ?ref= on the landing page. */
  code      String   @unique
  /** Unique visitors who opened the landing page via this link. */
  visits    Int      @default(0)
  createdAt DateTime @default(now())

  tenant  Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  course  Course @relation(fields: [courseId], references: [id], onDelete: Cascade)
  student User   @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([courseId, studentId])
}

model Module {
  id        String    @id @default(uuid()) @db.Uuid
  tenantId  String    @db.Uuid
  courseId  String    @db.Uuid
  title     String
  sortOrder Int       @default(0)
  /// Drip release: unlock this module only N days after the student enrolls (0 = immediate).
  dripDays  Int       @default(0)

  tenant    Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  course    Course    @relation(fields: [courseId], references: [id], onDelete: Cascade)
  lessons   Lesson[]
}

model Lesson {
  id            String    @id @default(uuid()) @db.Uuid
  tenantId      String    @db.Uuid
  moduleId      String    @db.Uuid
  title         String
  notes         String?   @db.Text
  videoPublicId String?
  durationSec   Int?
  sortOrder     Int       @default(0)

  tenant        Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  module        Module    @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  attachments   Attachment[]
  progress      Progress[]
}

model Attachment {
  id        String          @id @default(uuid()) @db.Uuid
  tenantId  String          @db.Uuid
  lessonId  String          @db.Uuid
  publicId  String
  filename  String
  kind      AttachmentKind  @default(OTHER)

  tenant    Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  lesson    Lesson          @relation(fields: [lessonId], references: [id], onDelete: Cascade)
}

model Progress {
  id              String    @id @default(uuid()) @db.Uuid
  tenantId        String    @db.Uuid
  studentId       String    @db.Uuid
  lessonId        String    @db.Uuid
  lastPositionSec Int       @default(0)
  completedAt     DateTime?
  updatedAt       DateTime  @updatedAt

  tenant          Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  student         User      @relation(fields: [studentId], references: [id], onDelete: Cascade)
  lesson          Lesson    @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  @@unique([studentId, lessonId])
}

/// One row per student per active learning day (any progress write that day).
/// Powers the streak counter and the journey activity calendar.
model LearningActivity {
  id        String   @id @default(uuid()) @db.Uuid
  tenantId  String   @db.Uuid
  studentId String   @db.Uuid
  /// Calendar day in Asia/Jerusalem, stored as a DATE.
  date      DateTime @db.Date
  createdAt DateTime @default(now())

  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  student   User     @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([studentId, date])
  @@index([tenantId])
  @@index([tenantId, studentId])
}

model Enrollment {
  id        String    @id @default(uuid()) @db.Uuid
  tenantId  String    @db.Uuid
  studentId String    @db.Uuid
  courseId  String    @db.Uuid
  createdAt DateTime  @default(now())

  tenant    Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  student   User      @relation(fields: [studentId], references: [id], onDelete: Cascade)
  course    Course    @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@unique([studentId, courseId])
}

// ─────────────────────────────────────────────────────────────────────────────
// Extended platform features. All are tenant-owned (denormalized tenantId +
// RLS in the matching migration + registered in scoped-prisma TENANT_MODELS).
// FKs (incl. ON DELETE CASCADE) live in the migration SQL; author/student
// display names are denormalized to avoid a web of User back-relations.
// ─────────────────────────────────────────────────────────────────────────────

/// In-app notification for one user (bell menu). Fed by broadcasts, Q&A answers,
/// community replies, new reviews, certificates, etc.
model Notification {
  id        String    @id @default(uuid()) @db.Uuid
  tenantId  String    @db.Uuid
  userId    String    @db.Uuid
  /// broadcast | qa_answer | community_reply | review | certificate | enroll
  type      String
  title     String
  body      String    @default("") @db.Text
  link      String?
  readAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([tenantId, userId, createdAt])
}

/// A message an owner blasts to students; delivery fans out into Notifications.
model Broadcast {
  id        String   @id @default(uuid()) @db.Uuid
  tenantId  String   @db.Uuid
  authorId  String   @db.Uuid
  /// null = all students in the tenant; otherwise students enrolled in this course.
  courseId  String?  @db.Uuid
  subject   String
  body      String   @db.Text
  sentCount Int      @default(0)
  createdAt DateTime @default(now())

  @@index([tenantId, createdAt])
}

/// A discussion thread in the tenant community.
model CommunityPost {
  id         String   @id @default(uuid()) @db.Uuid
  tenantId   String   @db.Uuid
  authorId   String   @db.Uuid
  authorName String
  authorRole String
  title      String
  body       String   @db.Text
  pinned     Boolean  @default(false)
  replyCount Int      @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([tenantId, pinned, createdAt])
}

/// A reply under a CommunityPost.
model CommunityReply {
  id         String   @id @default(uuid()) @db.Uuid
  tenantId   String   @db.Uuid
  postId     String   @db.Uuid
  authorId   String   @db.Uuid
  authorName String
  authorRole String
  body       String   @db.Text
  createdAt  DateTime @default(now())

  @@index([tenantId, postId, createdAt])
}

/// A student's question on a lesson, answered by staff.
model LessonQuestion {
  id           String    @id @default(uuid()) @db.Uuid
  tenantId     String    @db.Uuid
  lessonId     String    @db.Uuid
  courseId     String    @db.Uuid
  studentId    String    @db.Uuid
  studentName  String
  body         String    @db.Text
  answer       String    @default("") @db.Text
  answeredById String?   @db.Uuid
  answeredAt   DateTime?
  createdAt    DateTime  @default(now())

  @@index([tenantId, lessonId, createdAt])
}

/// A code a student redeems to enroll in a course for free (giveaways / manual sales).
model AccessCode {
  id        String    @id @default(uuid()) @db.Uuid
  tenantId  String    @db.Uuid
  courseId  String    @db.Uuid
  code      String    @unique
  maxUses   Int       @default(1)
  uses      Int       @default(0)
  expiresAt DateTime?
  createdAt DateTime  @default(now())

  @@index([tenantId, courseId])
}

/// A certificate issued when a student completes a course.
model Certificate {
  id        String   @id @default(uuid()) @db.Uuid
  tenantId  String   @db.Uuid
  courseId  String   @db.Uuid
  studentId String   @db.Uuid
  studentName String @default("")
  courseTitle String @default("")
  serial    String   @unique
  issuedAt  DateTime @default(now())

  @@unique([courseId, studentId])
  @@index([tenantId])
}

/// A student's private notes on one lesson.
model LessonNote {
  id        String   @id @default(uuid()) @db.Uuid
  tenantId  String   @db.Uuid
  studentId String   @db.Uuid
  lessonId  String   @db.Uuid
  courseId  String   @db.Uuid
  body      String   @default("") @db.Text
  updatedAt DateTime @updatedAt

  @@unique([studentId, lessonId])
  @@index([tenantId, studentId])
}

/// A catalog course a student saved for later.
model Wishlist {
  id        String   @id @default(uuid()) @db.Uuid
  tenantId  String   @db.Uuid
  studentId String   @db.Uuid
  courseId  String   @db.Uuid
  createdAt DateTime @default(now())

  @@unique([studentId, courseId])
  @@index([tenantId, studentId])
}
