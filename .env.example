# App user connection (non-superuser, subject to RLS)
DATABASE_URL=postgresql://kursim_app:kursim_app_pw@localhost:5432/kursim
# Superuser connection used ONLY for migrations/seed
MIGRATE_DATABASE_URL=postgresql://postgres:postgres@localhost:5432/kursim
REDIS_URL=redis://localhost:6379
# 32+ byte random secret for JWT signing (openssl rand -base64 32)
AUTH_SECRET=change-me-to-a-long-random-string
ACCESS_TOKEN_TTL_SECONDS=600
REFRESH_TOKEN_TTL_DAYS=30
APP_URL=http://localhost:3000
# Cloudinary (required for video upload/playback and landing galleries)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
# Initial platform administrator (created by the seed on first boot)
SEED_SUPERADMIN_EMAIL=admin@kursim.local
SEED_SUPERADMIN_PASSWORD=Admin1234!
# Affiliate program: unique landing-page visitors needed to earn one coin
AFFILIATE_VISITS_PER_COIN=100
