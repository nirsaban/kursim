# App user connection (non-superuser, subject to RLS)
DATABASE_URL=postgresql://kursim_app:kursim_app_pw@localhost:5432/kursim
# Superuser connection used ONLY for migrations/seed
MIGRATE_DATABASE_URL=postgresql://postgres:postgres@localhost:5432/kursim
REDIS_URL=redis://localhost:6379
# 32+ byte random secret for JWT signing (openssl rand -base64 32)
AUTH_SECRET=change-me-to-a-long-random-string
ACCESS_TOKEN_TTL_SECONDS=600
REFRESH_TOKEN_TTL_DAYS=30
APP_URL=http://localhost:3000
# Cloudinary (required for video upload/playback and landing galleries)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
# Initial platform administrator (created by the seed on first boot)
SEED_SUPERADMIN_EMAIL=admin@kursim.local
SEED_SUPERADMIN_PASSWORD=Admin1234!
# Affiliate program: unique landing-page visitors needed to earn one coin
AFFILIATE_VISITS_PER_COIN=100
# Gemini AI course-media generation (Veo video -> 240 scroll frames + Imagen stills).
# Prompt-writer, video, and image are all Gemini. Get a key at aistudio.google.com.
AI_MEDIA_ENABLED=false
# Veo billing is per-generation and expensive. Kept off independently of
# AI_MEDIA_ENABLED (Imagen stills still work without it) — only flip to true
# deliberately, after confirming the pipeline (ffmpeg, Imagen aspect ratios)
# is actually healthy, since a failed run after Veo succeeds still burns the cost.
AI_VIDEO_ENABLED=false
GEMINI_API_KEY=
GEMINI_TEXT_MODEL=gemini-3.1-pro-preview
GEMINI_VIDEO_MODEL=veo-3.1-fast-generate-preview
GEMINI_IMAGE_MODEL=imagen-4.0-generate-001
# WhatsApp (Baileys / WhatsApp Web) — used to send students their login after a
# Grow purchase. No API keys needed: the super-admin pairs one number by scanning
# a QR at /superadmin/whatsapp. The socket runs in the worker; auth persists in Redis.
BAILEYS_LOG_LEVEL=silent

# SMTP — transactional mail (purchase receipts + owner sale alerts).
# Leave SMTP_HOST empty to disable email delivery entirely.
SMTP_HOST=
SMTP_PORT=465
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=
